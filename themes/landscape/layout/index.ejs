<!DOCTYPE html>
<html lang="<%= config.language %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page.title || config.title %></title>
  <%- css('css/style') %>
</head>
<body>
  <header class="header">
    <h1 class="logo"><a href="<%= url_for() %>"><%= config.title %></a></h1>
  </header>
  <main class="content">
    <%- body %>
  </main>
  <footer class="footer">
    © <%= new Date().getFullYear() %> <%= config.title %>
  </footer>
  <%- js('js/script') %>
</body>
</html>
